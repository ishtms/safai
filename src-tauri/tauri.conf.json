{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Safai",
  "version": "0.2.0",
  "identifier": "dev.safai.app",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "title": "Safai",
        "width": 1240,
        "height": 800,
        "minWidth": 1100,
        "minHeight": 700,
        "decorations": false,
        "transparent": false,
        "resizable": true,
        "fullscreen": false,
        "center": true,
        "backgroundColor": "#1f2025"
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' data: blob:; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' data: https://fonts.gstatic.com; script-src 'self'; connect-src 'self' ipc: http://ipc.localhost https://updater.safai.dev"
    }
  },
  "plugins": {
    "updater": {
      "active": true,
      "endpoints": [
        "https://updater.safai.dev/{{target}}/{{current_version}}"
      ],
      "dialog": false,
      "pubkey": "REPLACE_WITH_TAURI_UPDATER_PUBKEY"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "category": "Utility",
    "shortDescription": "Open-source cross-platform system cleaner",
    "longDescription": "Safai is an open-source, cross-platform system cleaner: junk, duplicates, large & old files, privacy data, startup items, memory/activity, and malware - with an undo-safe cleaner engine so nothing is ever hard-deleted.",
    "copyright": "Copyright © 2026 Safai contributors",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [],
    "externalBin": [],
    "macOS": {
      "frameworks": [],
      "minimumSystemVersion": "10.15",
      "exceptionDomain": "",
      "signingIdentity": null,
      "providerShortName": null,
      "entitlements": null
    },
    "windows": {
      "certificateThumbprint": null,
      "digestAlgorithm": "sha256",
      "timestampUrl": "http://timestamp.sectigo.com",
      "webviewInstallMode": {
        "type": "downloadBootstrapper"
      },
      "nsis": {
        "installMode": "currentUser",
        "displayLanguageSelector": false,
        "installerIcon": "icons/icon.ico"
      }
    },
    "linux": {
      "deb": {
        "depends": []
      },
      "appimage": {
        "bundleMediaFramework": false
      }
    }
  }
}
